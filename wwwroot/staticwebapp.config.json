{
  "auth": {
    "rolesSource": "/api/GetRoles",
    "identityProviders": {
      "azureActiveDirectory": {
        "registration": {
          "openIdIssuer": "https://login.microsoftonline.com/4b30645b-0888-45c0-9481-712bde435ffd/v2.0",
          "clientIdSettingName": "AAD_CLIENT_ID",
          "clientSecretSettingName": "AAD_CLIENT_SECRET"
        }
      }
    }
  },
  "routes": [
    { "route": "/login",  "rewrite": "/.auth/login/aad" },
    { "route": "/logout", "redirect": "/.auth/logout" },

    { "route": "/api/GetRoles",            "allowedRoles": ["anonymous", "authenticated"] },
    { "route": "/api/ListarNotas",         "allowedRoles": ["submitter", "gestor", "financeiro_nf", "administrador"] },
    { "route": "/api/PostNota",            "allowedRoles": ["submitter", "gestor", "financeiro_nf", "administrador"] },
    { "route": "/api/AprovarNota",         "allowedRoles": ["gestor", "administrador"] },
    { "route": "/api/RejeitarNota",        "allowedRoles": ["gestor", "administrador"] },
    { "route": "/api/ListarFornecedores",  "allowedRoles": ["submitter", "gestor", "financeiro_nf", "administrador"] },
    { "route": "/api/PostFornecedor",      "allowedRoles": ["administrador"] },
    { "route": "/api/ImportarFornecedores","allowedRoles": ["administrador"] },
    { "route": "/api/EnviarNotificacao",   "allowedRoles": ["submitter", "gestor", "financeiro_nf", "administrador"] },

    { "route": "/admin/*", "allowedRoles": ["administrador"] },

    { "route": "/sem-acesso", "allowedRoles": ["anonymous", "authenticated"] },

    {
      "route": "/*",
      "allowedRoles": ["submitter", "gestor", "financeiro_nf", "administrador"]
    }
  ],
  "responseOverrides": {
    "401": {
      "redirect": "/.auth/login/aad",
      "statusCode": 302
    },
    "403": {
      "rewrite": "/sem-acesso.html",
      "statusCode": 403
    }
  },
  "globalHeaders": {
    "X-Frame-Options": "DENY",
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  },
  "mimeTypes": {
    ".json": "application/json"
  }
}
